# ------------------------------------------------------------------
# Server Health Check and Alerting Script - configuration
#
# Copy this file to config.env and edit the values for your setup:
#   cp config.example.env config.env
#
# config.env is sourced directly by health_check.sh, so it must be
# valid bash. Do not commit config.env if it contains a real webhook
# URL - keep it out of git (see .gitignore).
# ------------------------------------------------------------------

# Hosts to check. Use "localhost" for the machine the script runs on.
# Additional entries are checked over SSH - see SSH_USER / SSH_KEY below.
HOSTS=(localhost)

# --- Alert thresholds ---
DISK_THRESHOLD=80          # percent used, per mounted filesystem
MEMORY_THRESHOLD=90        # percent used
CPU_LOAD_THRESHOLD=2.0     # 1-minute load average

# Critical systemd services to check (unit names, no ".service" needed)
SERVICES=(ssh)

# --- Alerting ---
# Slack or Discord incoming webhook URL. During development, point this
# at a https://webhook.site URL so you can see payloads without spamming
# a real channel.
WEBHOOK_URL="https://webhook.site/replace-with-your-test-url"

# Minimum seconds between repeat alerts for the same unresolved issue.
# Set higher to reduce alert spam for long-lived problems.
ALERT_COOLDOWN_SECONDS=1800

# --- Logging / state ---
LOG_FILE="./logs/health_check.log"

# Directory used to remember which issues are already alerting, so the
# script can detect resolution and avoid re-alerting every run.
STATE_DIR="./logs/state"

# --- SSH (only needed for remote HOSTS entries) ---
SSH_USER="ubuntu"
SSH_KEY="$HOME/.ssh/id_rsa"
SSH_TIMEOUT=5
